{
  "model": {
    "text_backend": "huggingface",
    "text_model_name": "allenai/scibert_scivocab_uncased",
    "text_pooling": "first",
    "clip_dim": 512,
    "freeze_text_backbone": false,
    "train_text_layernorm_only": false,
    "train_top_n_layers": 3
  },
  "training": {
    "epochs": 100000,
    "batch_size": 128,
    "learning_rate": 1e-4,
    "weight_decay": 0.01,
    "use_validation": true,
    "val_split": 0.1,
    "val_seed": 42,
    "use_wandb": true,
    "wandb_project": "material-elastic-2d-symmetry",
    "log_interval": 50,
    "early_stopping": true,
    "early_stopping_patience": 20,
    "early_stopping_metric": "val_loss",
    "early_stopping_mode": "min"
  },
  "tensor_regression": {
    "task": "elastic_2d_symmetry",
    "modality": "text",
    "tensor_dim": 6,
    "tensor_mode": "voigt2d",
    "normalize_tensor": true,
    "clip_checkpoint_path": "data_preparation/news/runs/t5-base_equiformer_001_scibert/checkpoints/best_model.pt",

    "head_type": "dual",
    "head_hidden_dims": [512, 256],
    "head_dropout": 0.1,

    "training_phase": "phase2",
    "freeze_clip": false,
    "clip_loss_weight": 0.01,
    "regression_loss_weight": 1.0,
    "loss_fn": "mse",
    "regression_lr": 1e-4,

    "beta_prior": 1.2,
    "lambda_sym": 1,
    "lambda_sym_schedule": {
      "start": 0.1,
      "end": 1,
      "warmup_epochs": 1000
    },
    "freeze_alpha_head": true,
    "phase1_epochs": 30,

    "log_parity_plot": true,
    "parity_plot_interval": 10
  }
}
